# === Service ===
SERVICE_PORT=8000

# Optional extra CORS origin (besides localhost:5173, localhost:3000, and *.vercel.app)
ALLOWED_ORIGIN=

# === Database (Prisma) ===
# Supabase: Settings > Database > Connection string
#
# DATABASE_URL → runtime queries. Use the Transaction pooler (port 6543) with `pgbouncer=true`.
# DIRECT_URL   → migrations and `prisma db pull`. Use the Session pooler (port 5432) or
#                the direct connection (`db.<ref>.supabase.co:5432`).
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxxxxxxxxxx:your-password@aws-X-XX-XXXX-X.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxxxxxxxxxxxxxxxxx:your-password@aws-X-XX-XXXX-X.pooler.supabase.com:5432/postgres?sslmode=require"

# === Supabase ===
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Supabase: Settings > API > JWT Settings > JWT Secret (legacy HS256 secret).
# Used by Passport to validate access tokens issued by Supabase Auth.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
