// Prisma schema for Fundz (NestJS + Supabase Auth).
//
// Mapping notes:
//   - DB tables are singular snake_case; TypeScript uses PascalCase models
//     with `@@map("...")` to preserve the physical table names.
//   - DB columns are snake_case. Prisma Client exposes camelCase via `@map`.
//   - RLS is enabled on all tables in Supabase. The backend connects via the
//     pooler using the `postgres` role (bypasses RLS), and every query is
//     scoped by `userId` at the service layer — IDOR hardening.
//   - `profiles.id` = `auth.users.id` (Supabase Auth). The FK to auth.users
//     is enforced at DB level via migration SQL (cross-schema, not modeled
//     by Prisma). Prisma treats `id` as a plain UUID primary key.
//
// Commands:
//   npx prisma generate          — regenerate the client after schema changes
//   npx prisma migrate dev       — create + apply a migration locally
//   npx prisma migrate deploy    — apply pending migrations (CI / prod)
//   npx prisma db pull           — reverse-engineer schema from the DB
//   npx prisma db seed           — run prisma/seed.ts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------------------------------------------
// Profile (Supabase Auth — profiles.id = auth.users.id)
// -----------------------------------------------------------------------------
/// Main user record. `id` is always set to the corresponding `auth.users.id`
/// from Supabase Auth (UUID, NOT auto-generated by Prisma).
/// The FK to `auth.users` is enforced at DB level (see migration SQL).
model Profile {
  id        String    @id @db.Uuid
  email     String?   @unique @db.VarChar
  name      String?
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  accounts      Account[]
  categories    Category[]
  goals         Goal[]
  installments  Installment[]
  subscriptions Subscription[]
  transactions  Transaction[]

  @@map("profiles")
}

// -----------------------------------------------------------------------------
// Account
// -----------------------------------------------------------------------------
/// Row Level Security is enabled on this table in Supabase.
model Account {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  name      String    @db.VarChar
  type      String    @db.VarChar
  balance   Decimal?  @default(0) @db.Decimal
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  profile       Profile        @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_accounts_user")
  installments  Installment[]
  subscriptions Subscription[]
  transactions  Transaction[]

  @@map("accounts")
}

// -----------------------------------------------------------------------------
// Category
// -----------------------------------------------------------------------------
/// Row Level Security is enabled on this table in Supabase.
model Category {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  name      String    @db.VarChar
  type      String    @db.VarChar // "income" | "expense"
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  profile       Profile        @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_categories_user")
  installments  Installment[]
  subscriptions Subscription[]
  transactions  Transaction[]

  @@map("categories")
}

// -----------------------------------------------------------------------------
// Goal
// -----------------------------------------------------------------------------
/// Row Level Security is enabled on this table in Supabase.
model Goal {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  name          String    @db.VarChar
  targetAmount  Decimal   @map("target_amount") @db.Decimal
  currentAmount Decimal?  @default(0) @map("current_amount") @db.Decimal
  dueDate       DateTime? @map("due_date") @db.Date
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  profile Profile @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_goals_user")

  @@map("goals")
}

// -----------------------------------------------------------------------------
// Subscription
// -----------------------------------------------------------------------------
/// Row Level Security is enabled on this table in Supabase.
model Subscription {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  accountId       String?   @map("account_id") @db.Uuid
  categoryId      String?   @map("category_id") @db.Uuid
  name            String    @db.VarChar
  amount          Decimal   @db.Decimal
  billingCycle    String    @map("billing_cycle") @db.VarChar // "monthly" | "yearly"
  nextBillingDate DateTime? @map("next_billing_date") @db.Date
  active          Boolean?  @default(true)
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  profile  Profile   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_subscriptions_user")
  account  Account?  @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_subscriptions_account")
  category Category? @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_subscriptions_category")

  @@map("subscriptions")
}

// -----------------------------------------------------------------------------
// Installment (Parcelamento)
// -----------------------------------------------------------------------------
/// Row Level Security is enabled on this table in Supabase.
model Installment {
  id                String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  accountId         String?   @map("account_id") @db.Uuid
  categoryId        String?   @map("category_id") @db.Uuid
  name              String    @db.VarChar
  totalAmount       Decimal   @map("total_amount") @db.Decimal
  installmentAmount Decimal   @map("installment_amount") @db.Decimal
  totalInstallments Int       @map("total_installments")
  paidInstallments  Int       @default(0) @map("paid_installments")
  startDate         DateTime  @map("start_date") @db.Date
  billingDay        Int       @map("billing_day") // dia do vencimento (1-31)
  active            Boolean?  @default(true)
  createdAt         DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  profile  Profile   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_installments_user")
  account  Account?  @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_installments_account")
  category Category? @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_installments_category")

  @@map("installments")
}

// -----------------------------------------------------------------------------
// Transaction
// -----------------------------------------------------------------------------
/// Row Level Security is enabled on this table in Supabase.
model Transaction {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  accountId   String    @map("account_id") @db.Uuid
  categoryId  String?   @map("category_id") @db.Uuid
  amount      Decimal   @db.Decimal
  type        String    @db.VarChar // "income" | "expense"
  description String?   @db.VarChar
  occurredAt  DateTime  @default(now()) @map("occurred_at") @db.Timestamp(6)
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  profile  Profile   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_transactions_user")
  account  Account   @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_transactions_account")
  category Category? @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_transactions_category")

  @@map("transactions")
}
